{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ConfigRoot",
  "description": "Root of the authored configuration (all layers merged).",
  "type": "object",
  "properties": {
    "content": {
      "description": "`content.*` — content definitions the core reads as data\n(docs/40-parameterisation.md §2.2, §3): the terrain type catalogue today.",
      "type": "object",
      "properties": {
        "terrain": {
          "description": "`content.terrain.*` — the terrain type catalogue.",
          "type": "object",
          "properties": {
            "mountain": {
              "description": "`content.terrain.mountain.*` — the high-ground band.",
              "type": "object",
              "properties": {
                "min_height": {
                  "description": "`content.terrain.mountain.min_height` — height at or above which a\nvertex is mountain. Any value.",
                  "type": "integer",
                  "format": "int32"
                }
              },
              "additionalProperties": false,
              "required": [
                "min_height"
              ]
            },
            "rock": {
              "description": "`content.terrain.rock.*` — rock (terrain-owned immovable).",
              "type": "object",
              "properties": {
                "density_permille": {
                  "description": "`content.terrain.rock.density_permille` — rock per 1000 eligible\nmountain vertices. Bounded by the per-mille base.",
                  "type": "integer",
                  "format": "uint32",
                  "maximum": 1000,
                  "minimum": 0
                }
              },
              "additionalProperties": false,
              "required": [
                "density_permille"
              ]
            },
            "shore": {
              "description": "`content.terrain.shore.*` — the coastal band.",
              "type": "object",
              "properties": {
                "band": {
                  "description": "`content.terrain.shore.band` — height steps above sea level still\ncounted as shore. Any value (0 = no shore band).",
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0
                }
              },
              "additionalProperties": false,
              "required": [
                "band"
              ]
            },
            "tree": {
              "description": "`content.terrain.tree.*` — trees (terrain-owned immovable).",
              "type": "object",
              "properties": {
                "density_permille": {
                  "description": "`content.terrain.tree.density_permille` — trees per 1000 eligible land\nvertices. A probability, so it is bounded by the per-mille base.",
                  "type": "integer",
                  "format": "uint32",
                  "maximum": 1000,
                  "minimum": 0
                }
              },
              "additionalProperties": false,
              "required": [
                "density_permille"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "shore",
            "mountain",
            "tree",
            "rock"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "terrain"
      ]
    },
    "input": {
      "description": "`input.*` — input mapping & sensitivities (ADR 0022; issue #9 Phase 2).\nProjected into a standalone [`InputParams`], like `render.*` and for the\nsame reason: input bindings are presentation/UX, outside the determinism\nboundary (docs/40-parameterisation.md §2.2).",
      "type": "object",
      "properties": {
        "shape": {
          "description": "`input.shape.*` — the terrain-shaping controls.",
          "type": "object",
          "properties": {
            "click_drag_threshold_px": {
              "description": "`input.shape.click_drag_threshold_px` — max cursor motion (physical\npixels) still counted as a shaping click. Non-negative; 0 makes any\nmotion a drag.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            },
            "lower_button": {
              "description": "`input.shape.lower_button` — the pointer button that lowers it.",
              "oneOf": [
                {
                  "description": "The left mouse button.",
                  "type": "string",
                  "const": "left"
                },
                {
                  "description": "The right mouse button.",
                  "type": "string",
                  "const": "right"
                },
                {
                  "description": "The middle mouse button (wheel click).",
                  "type": "string",
                  "const": "middle"
                }
              ]
            },
            "raise_button": {
              "description": "`input.shape.raise_button` — the pointer button that raises the picked\nvertex.",
              "oneOf": [
                {
                  "description": "The left mouse button.",
                  "type": "string",
                  "const": "left"
                },
                {
                  "description": "The right mouse button.",
                  "type": "string",
                  "const": "right"
                },
                {
                  "description": "The middle mouse button (wheel click).",
                  "type": "string",
                  "const": "middle"
                }
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "raise_button",
            "lower_button",
            "click_drag_threshold_px"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "shape"
      ]
    },
    "meta": {
      "description": "`meta.*` — config/schema versioning and provenance.",
      "type": "object",
      "properties": {
        "schema_version": {
          "description": "`meta.schema_version` — the schema this config targets; a mismatch\ntriggers the migration path, never a silent misread.",
          "type": "integer",
          "format": "uint32",
          "minimum": 1
        }
      },
      "additionalProperties": false,
      "required": [
        "schema_version"
      ]
    },
    "render": {
      "description": "`render.*` — presentation parameters for the workbench renderer\n(ADR 0020 §4). Projected into a standalone [`RenderParams`] — **not**\ninto the core-injected [`Params`], because presentation is outside the\ndeterminism boundary (docs/40-parameterisation.md §2.2).",
      "type": "object",
      "properties": {
        "animation": {
          "description": "`render.animation.*` — the shaping-change animation (ADR 0022 §5; issue\n#9/#10 Phase 3).",
          "type": "object",
          "properties": {
            "duration_ms": {
              "description": "`render.animation.duration_ms` — per-vertex settle time (ms) for a shaping\nchange. Non-negative; 0 snaps instantly.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            },
            "ripple_ms_per_unit": {
              "description": "`render.animation.ripple_ms_per_unit` — per-unit-distance start delay that\nmakes the cascade ripple outward (issue #9/#10 Phase 4). Non-negative; 0\nsettles the whole change together.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            }
          },
          "additionalProperties": false,
          "required": [
            "duration_ms",
            "ripple_ms_per_unit"
          ]
        },
        "background": {
          "description": "`render.background.*` — the surface the world is drawn against.",
          "type": "object",
          "properties": {
            "rgb": {
              "description": "`render.background.rgb` — clear colour, linear RGB.",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              },
              "maxItems": 3,
              "minItems": 3
            }
          },
          "additionalProperties": false,
          "required": [
            "rgb"
          ]
        },
        "camera": {
          "description": "`render.camera.*` — the view camera.",
          "type": "object",
          "properties": {
            "far": {
              "description": "`render.camera.far` — far clip-plane distance.",
              "type": "number",
              "format": "float"
            },
            "fov_degrees": {
              "description": "`render.camera.fov_degrees` — vertical field of view, in degrees.",
              "type": "number",
              "format": "float",
              "maximum": 179.0,
              "minimum": 1.0
            },
            "initial_distance": {
              "description": "`render.camera.initial_distance` — starting orbit distance from target.",
              "type": "number",
              "format": "float"
            },
            "initial_pitch_degrees": {
              "description": "`render.camera.initial_pitch_degrees` — starting orbit pitch, in degrees.",
              "type": "number",
              "format": "float"
            },
            "initial_yaw_degrees": {
              "description": "`render.camera.initial_yaw_degrees` — starting orbit yaw, in degrees.",
              "type": "number",
              "format": "float"
            },
            "max_distance": {
              "description": "`render.camera.max_distance` — farthest the zoom may pull back. Positive.",
              "type": "number",
              "format": "float",
              "minimum": 0.001
            },
            "max_pitch_degrees": {
              "description": "`render.camera.max_pitch_degrees` — highest tilt, also within `(-90, 90)`.",
              "type": "number",
              "format": "float",
              "maximum": 89.0,
              "minimum": -89.0
            },
            "min_distance": {
              "description": "`render.camera.min_distance` — closest the zoom may dolly in. Positive,\nso the eye can never sit on the target.",
              "type": "number",
              "format": "float",
              "minimum": 0.001
            },
            "min_pitch_degrees": {
              "description": "`render.camera.min_pitch_degrees` — lowest tilt. Held within `(-90, 90)`\nso the look-at framing never degenerates at the pole.",
              "type": "number",
              "format": "float",
              "maximum": 89.0,
              "minimum": -89.0
            },
            "near": {
              "description": "`render.camera.near` — near clip-plane distance.",
              "type": "number",
              "format": "float"
            },
            "orbit_speed": {
              "description": "`render.camera.orbit_speed` — degrees of rotation per pixel of drag.\nNon-negative (0 pins the orbit).",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            },
            "pan_speed": {
              "description": "`render.camera.pan_speed` — world units of look-at translation per pixel\nof drag. Non-negative.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            },
            "zoom_speed": {
              "description": "`render.camera.zoom_speed` — fraction of the current distance changed per\nunit of scroll. Non-negative.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            }
          },
          "additionalProperties": false,
          "required": [
            "fov_degrees",
            "near",
            "far",
            "initial_distance",
            "initial_yaw_degrees",
            "initial_pitch_degrees",
            "min_distance",
            "max_distance",
            "min_pitch_degrees",
            "max_pitch_degrees",
            "orbit_speed",
            "pan_speed",
            "zoom_speed"
          ]
        },
        "hud": {
          "description": "`render.hud.*` — the read-only debug/HUD overlay (ADR 0015; issue #8\nPhase 3).",
          "type": "object",
          "properties": {
            "enabled": {
              "description": "`render.hud.enabled` — draw the overlay (only when the `debug-hud`\nfeature is compiled in).",
              "type": "boolean"
            },
            "show_camera": {
              "description": "`render.hud.show_camera` — show the camera-pose section.",
              "type": "boolean"
            },
            "show_reticle": {
              "description": "`render.hud.show_reticle` — show the reticle vertex/height section.",
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "enabled",
            "show_camera",
            "show_reticle"
          ]
        },
        "lighting": {
          "description": "`render.lighting.*` — the directional light shading the surface.",
          "type": "object",
          "properties": {
            "ambient": {
              "description": "`render.lighting.ambient` — ambient light fraction in `[0, 1]`.",
              "type": "number",
              "format": "float",
              "maximum": 1.0,
              "minimum": 0.0
            },
            "azimuth_degrees": {
              "description": "`render.lighting.azimuth_degrees` — light compass direction, in degrees.",
              "type": "number",
              "format": "float"
            },
            "diffuse": {
              "description": "`render.lighting.diffuse` — diffuse light fraction in `[0, 1]`.",
              "type": "number",
              "format": "float",
              "maximum": 1.0,
              "minimum": 0.0
            },
            "elevation_degrees": {
              "description": "`render.lighting.elevation_degrees` — light angle above the horizon.",
              "type": "number",
              "format": "float"
            }
          },
          "additionalProperties": false,
          "required": [
            "azimuth_degrees",
            "elevation_degrees",
            "ambient",
            "diffuse"
          ]
        },
        "material": {
          "description": "`render.material.*` — the terrain-type material table (ADR 0023).",
          "type": "object",
          "properties": {
            "land_rgb": {
              "description": "`render.material.land_rgb` — ordinary grassy lowland, linear RGB.",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              },
              "maxItems": 3,
              "minItems": 3
            },
            "mountain_rgb": {
              "description": "`render.material.mountain_rgb` — bare rock at the mountain band base,\nlinear RGB.",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              },
              "maxItems": 3,
              "minItems": 3
            },
            "peak_rgb": {
              "description": "`render.material.peak_rgb` — snow the mountain band ramps toward at its\nhighest vertices, linear RGB.",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              },
              "maxItems": 3,
              "minItems": 3
            },
            "shore_rgb": {
              "description": "`render.material.shore_rgb` — the sandy coastal band, linear RGB.",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              },
              "maxItems": 3,
              "minItems": 3
            },
            "water_rgb": {
              "description": "`render.material.water_rgb` — underwater seabed colour, linear RGB.",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              },
              "maxItems": 3,
              "minItems": 3
            }
          },
          "additionalProperties": false,
          "required": [
            "water_rgb",
            "shore_rgb",
            "land_rgb",
            "mountain_rgb",
            "peak_rgb"
          ]
        },
        "mesh": {
          "description": "`render.mesh.*` — how the height field becomes a drawable surface.",
          "type": "object",
          "properties": {
            "vertical_scale": {
              "description": "`render.mesh.vertical_scale` — world height of one integer step. A\nnon-negative presentation scale; 0 flattens the relief (degenerate but\nvalid), and negatives (which would invert it) are rejected.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            }
          },
          "additionalProperties": false,
          "required": [
            "vertical_scale"
          ]
        },
        "water": {
          "description": "`render.water.*` — the living water surface (ADR 0023, Phase 2).",
          "type": "object",
          "properties": {
            "opacity": {
              "description": "`render.water.opacity` — base surface alpha, in `[0, 1]`.",
              "type": "number",
              "format": "float",
              "maximum": 1.0,
              "minimum": 0.0
            },
            "rgb": {
              "description": "`render.water.rgb` — the water surface colour, linear RGB.",
              "type": "array",
              "items": {
                "type": "number",
                "format": "float"
              },
              "maxItems": 3,
              "minItems": 3
            },
            "ripple_amplitude": {
              "description": "`render.water.ripple_amplitude` — shimmer brightness modulation.\nNon-negative; 0 is a still sea.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            },
            "ripple_scale": {
              "description": "`render.water.ripple_scale` — shimmer spatial frequency (radians/world\nunit). Non-negative; 0 makes the whole sea pulse as one.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            },
            "ripple_speed": {
              "description": "`render.water.ripple_speed` — shimmer travel speed (radians/second).\nNon-negative; 0 freezes the pattern.",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            },
            "surface_lift": {
              "description": "`render.water.surface_lift` — world units the drawn surface sits above the\nseabed datum. Non-negative (0 places it exactly on the flat seabed).",
              "type": "number",
              "format": "float",
              "minimum": 0.0
            }
          },
          "additionalProperties": false,
          "required": [
            "rgb",
            "opacity",
            "surface_lift",
            "ripple_amplitude",
            "ripple_speed",
            "ripple_scale"
          ]
        },
        "window": {
          "description": "`render.window.*` — the on-screen surface (and headless-capture size).",
          "type": "object",
          "properties": {
            "height": {
              "description": "`render.window.height` — initial surface height, in physical pixels.",
              "type": "integer",
              "format": "uint32",
              "minimum": 1
            },
            "width": {
              "description": "`render.window.width` — initial surface width, in physical pixels.",
              "type": "integer",
              "format": "uint32",
              "minimum": 1
            }
          },
          "additionalProperties": false,
          "required": [
            "width",
            "height"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "camera",
        "lighting",
        "material",
        "water",
        "background",
        "mesh",
        "window",
        "hud",
        "animation"
      ]
    },
    "sim": {
      "description": "`sim.*` — deterministic-simulation parameters.",
      "type": "object",
      "properties": {
        "economy": {
          "description": "`sim.economy.*` — the faith/mana economy subsystem.",
          "type": "object",
          "properties": {
            "mana": {
              "description": "`sim.economy.mana.*` — the mana resource.",
              "type": "object",
              "properties": {
                "mode": {
                  "description": "`sim.economy.mana.mode` — mana generation mode (ADR 0016 §3).\nHot-reloadable (a pure balance/exploration value).",
                  "oneOf": [
                    {
                      "description": "Ordinary metered mana — the governed default.",
                      "type": "string",
                      "const": "normal"
                    },
                    {
                      "description": "Accelerated regeneration for quicker iteration.",
                      "type": "string",
                      "const": "fast"
                    },
                    {
                      "description": "Effectively infinite mana; the sandbox god-mode value.",
                      "type": "string",
                      "const": "unlimited"
                    }
                  ]
                }
              },
              "additionalProperties": false,
              "required": [
                "mode"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "mana"
          ]
        },
        "opponent": {
          "description": "`sim.opponent.*` — the rival-deity subsystem.",
          "type": "object",
          "properties": {
            "enabled": {
              "description": "`sim.opponent.enabled` — `false` ⇒ no rival deity casts against the\nplayer. The general `sim.<subsystem>.enabled` isolation seam.",
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "enabled"
          ]
        },
        "placeholder": {
          "description": "`sim.placeholder.*` — Phase-1 gate scaffolding (contract §7.2);\ndeleted when the Phase-3 core consumes real subsystem state.",
          "type": "object",
          "properties": {
            "tick_increment": {
              "description": "`sim.placeholder.tick_increment` — ticks the placeholder state\nadvances per step. Hot-reloadable (a pure balance value).",
              "type": "integer",
              "format": "uint64",
              "minimum": 1
            }
          },
          "additionalProperties": false,
          "required": [
            "tick_increment"
          ]
        },
        "terrain": {
          "description": "`sim.terrain.*` — the vertex height-field subsystem (ADR 0017).",
          "type": "object",
          "properties": {
            "max_height": {
              "description": "`sim.terrain.max_height` — the world height ceiling a raise cannot\nexceed; bounds the cascade radius (ADR 0017 §3).",
              "type": "integer",
              "format": "int32",
              "minimum": 1
            },
            "max_step": {
              "description": "`sim.terrain.max_step` — maximum orthogonal height step; the step\ninvariant (ADR 0017 §2). Structural: the model assumes 1.",
              "type": "integer",
              "format": "uint32",
              "minimum": 1
            },
            "raise": {
              "description": "`sim.terrain.raise.*` — the raise/lower shaping operation.",
              "type": "object",
              "properties": {
                "mana_cost": {
                  "description": "`sim.terrain.raise.mana_cost` — mana per vertex actually moved\n(ADR 0017 §3). Any value is valid (0 = free shaping in exploration).",
                  "type": "integer",
                  "format": "uint32",
                  "minimum": 0
                }
              },
              "additionalProperties": false,
              "required": [
                "mana_cost"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "max_step",
            "max_height",
            "raise"
          ]
        },
        "winloss": {
          "description": "`sim.winloss.*` — the win/loss evaluation subsystem.",
          "type": "object",
          "properties": {
            "enabled": {
              "description": "`sim.winloss.enabled` — `false` ⇒ no win/loss evaluation during free\nplay. The general `sim.<subsystem>.enabled` isolation seam.",
              "type": "boolean"
            }
          },
          "additionalProperties": false,
          "required": [
            "enabled"
          ]
        },
        "worldgen": {
          "description": "`sim.worldgen.*` — the seeded world generator (ADR 0021).",
          "type": "object",
          "properties": {
            "detail": {
              "description": "`sim.worldgen.detail` — number of noise octaves. Bounded to a small\nrange: past a handful, octaves fall below the fixed-point floor.",
              "type": "integer",
              "format": "uint32",
              "maximum": 8,
              "minimum": 1
            },
            "feature_size": {
              "description": "`sim.worldgen.feature_size` — base noise wavelength in vertices. Bounded\naway from 0 (a wavelength must be positive) and capped so the coarse\nmasks stay in range.",
              "type": "integer",
              "format": "uint32",
              "maximum": 1024,
              "minimum": 1
            },
            "height": {
              "description": "`sim.worldgen.height` — map height (depth) in vertices.",
              "type": "integer",
              "format": "uint32",
              "maximum": 1024,
              "minimum": 2
            },
            "land_percent": {
              "description": "`sim.worldgen.land_percent` — target percentage of the map above sea\nlevel. Held inside `(0, 100)` so neither an all-sea nor all-land world\nis asked for.",
              "type": "integer",
              "format": "uint32",
              "maximum": 99,
              "minimum": 1
            },
            "relief": {
              "description": "`sim.worldgen.relief` — the vertical drama: max height steps land rises\nabove sea level. At least 1 (a flat, all-shore world).",
              "type": "integer",
              "format": "int32",
              "minimum": 1
            },
            "sea_level": {
              "description": "`sim.worldgen.sea_level` — the waterline datum. Signed; any value.",
              "type": "integer",
              "format": "int32"
            },
            "seed": {
              "description": "`sim.worldgen.seed` — the `u64` the generator draws from. Any value is\nvalid; it names the specific world within the chosen flavour.",
              "type": "integer",
              "format": "uint64",
              "minimum": 0
            },
            "shape": {
              "description": "`sim.worldgen.shape` — the land-arrangement mode (ADR 0021 §2a).",
              "oneOf": [
                {
                  "description": "One landmass ringed by sea (the shipped default).",
                  "type": "string",
                  "const": "island"
                },
                {
                  "description": "Land filling most of the map, receding to a coastline at the edges.",
                  "type": "string",
                  "const": "continent"
                },
                {
                  "description": "Several scattered islands.",
                  "type": "string",
                  "const": "archipelago"
                },
                {
                  "description": "Mostly land with interior lakes.",
                  "type": "string",
                  "const": "inland"
                }
              ]
            },
            "width": {
              "description": "`sim.worldgen.width` — map width in vertices. Bounded so a world is\nlarge enough to read and small enough to generate cheaply.",
              "type": "integer",
              "format": "uint32",
              "maximum": 1024,
              "minimum": 2
            }
          },
          "additionalProperties": false,
          "required": [
            "width",
            "height",
            "seed",
            "sea_level",
            "land_percent",
            "shape",
            "relief",
            "feature_size",
            "detail"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "worldgen",
        "opponent",
        "economy",
        "winloss",
        "terrain",
        "placeholder"
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "sim",
    "content",
    "render",
    "input"
  ]
}
